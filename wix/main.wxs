<?xml version='1.0' encoding='windows-1252'?>

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='PrivChat'
        UpgradeCode='DE94A20F-9E92-4879-83C3-50178E8FDB83'
        Manufacturer='NetOnStream'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='PrivChat Desktop Messenger'
            Manufacturer='NetOnStream'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='PrivChat Installation'/>

        <!-- Product icon shown in Add/Remove Programs -->
        <Icon Id='ProductICO' SourceFile='assets\icon.ico'/>
        <Property Id='ARPPRODUCTICON' Value='ProductICO' />

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='PrivChat'>

                    <Component Id='License' Guid='*'>
                        <File Id='LicenseFile'
                            DiskId='1'
                            Source='wix\License.rtf'
                            KeyPath='yes'/>
                    </Component>

                    <Directory Id='Bin' Name='bin'>
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='privchat-iced.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\privchat-iced.exe'
                                KeyPath='yes'/>
                        </Component>
                    </Directory>
                </Directory>
            </Directory>

            <!-- Desktop shortcut -->
            <Directory Id='DesktopFolder' Name='Desktop'>
                <Component Id='DesktopShortcut' Guid='A1B2C3D4-E5F6-7890-ABCD-EF1234567890'>
                    <Shortcut Id='DesktopShortcutLink'
                        Name='PrivChat'
                        Description='PrivChat Desktop Messenger'
                        Target='[Bin]privchat-iced.exe'
                        WorkingDirectory='Bin'
                        Icon='ProductICO'/>
                    <RemoveFolder Id='RemoveDesktopShortcutFolder' On='uninstall'/>
                    <RegistryValue Root='HKCU' Key='Software\NetOnStream\PrivChat'
                        Name='DesktopShortcut' Type='integer' Value='1' KeyPath='yes'/>
                </Component>
            </Directory>

            <!-- Start Menu shortcut -->
            <Directory Id='ProgramMenuFolder' Name='Programs'>
                <Directory Id='ProgramMenuDir' Name='PrivChat'>
                    <Component Id='StartMenuShortcut' Guid='B2C3D4E5-F6A7-8901-BCDE-F12345678901'>
                        <Shortcut Id='StartMenuShortcutLink'
                            Name='PrivChat'
                            Description='PrivChat Desktop Messenger'
                            Target='[Bin]privchat-iced.exe'
                            WorkingDirectory='Bin'
                            Icon='ProductICO'/>
                        <RemoveFolder Id='RemoveProgramMenuDir' On='uninstall'/>
                        <RegistryValue Root='HKCU' Key='Software\NetOnStream\PrivChat'
                            Name='StartMenuShortcut' Type='integer' Value='1' KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs PrivChat and creates shortcuts.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>

            <ComponentRef Id='License'/>
            <ComponentRef Id='binary0'/>
            <ComponentRef Id='DesktopShortcut'/>
            <ComponentRef Id='StartMenuShortcut'/>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
        </UI>

        <WixVariable Id='WixUILicenseRtf' Value='wix\License.rtf'/>

    </Product>

</Wix>
